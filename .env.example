# PostgreSQL DSN — used only by the API service
DATABASE_URL=postgres://daily_patch:changeme@postgres:5432/daily_patch?sslmode=disable

# Shared secret for service-to-service API auth
API_INTERNAL_SECRET=changeme

# Anthropic API key — used directly by the anthropic SDK in scorer/generator
ANTHROPIC_API_KEY=sk-ant-...

# Vulnerability source credentials
NVD_API_KEY=
GITHUB_TOKEN=

# SMTP password — used by the delivery layer when email is enabled
SMTP_PASSWORD=
